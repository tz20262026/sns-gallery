# SNS Gallery Environment Variables
# Copy this file to .env and fill in your actual values

# ── Stripe (Payment) ──────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_REPLACE_WITH_YOUR_KEY

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Google Gemini (for image labeling) ───────────────────────────────────────
# Already configured in 01_SNS運用/spreadsheet_bot/.env
# GEMINI_API_KEY=your_key_here
